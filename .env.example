# Postgres connection string from Neon / Supabase / etc.
# Example: postgresql://user:password@host/db?sslmode=require
DATABASE_URL=

# Optional: shared secret protecting the /api/cron/sync endpoint
# Generate with: openssl rand -base64 32
CRON_SECRET=

# Hard cap on rows per source (qatarliving, qatarsale, mzadqatar). After each
# successful sync, the oldest rows by lastSeenAt are deleted until the source is
# at this count. Default 500.
PRUNE_MAX_PER_SOURCE=500

# ScraperAPI key — used by the Mzad Qatar adapter to fetch pages through a
# Cloudflare-solving proxy (the only viable way to reach mzadqatar.com).
# Sign up at https://www.scraperapi.com/ — also set this as a GitHub Actions secret.
SCRAPERAPI_KEY=

# Shared secret the mobile (Android) app sends as the `x-api-key` header to read
# the /api/* routes. Generate with: openssl rand -base64 32
# Set the same value as EXPO_PUBLIC_API_KEY when building the app.
MOBILE_API_KEY=
